# AWS RDS PostgreSQL:
# Use this after starting the local SSM port-forward tunnel to the bastion.
DATABASE_URL="postgresql://qa_admin:<password>@127.0.0.1:5432/qa_dashboard"
PORT=4000
NODE_ENV=development
DB_POOL_MAX=10

# Planned Azure DevOps integration. Keep PATs server-side only.
# Shared fallback token used when a team hasn't stored its own PAT.
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# Encrypts per-team Azure DevOps PATs at rest (AES-256-GCM, 32 bytes hex-encoded).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
